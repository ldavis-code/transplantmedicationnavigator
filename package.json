{
  "name": "transplant-medication-navigator",
  "version": "1.0.0",
  "description": "From Prescription to Possession - Free guide for transplant patients",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run check:readability && node scripts/generate-sitemap.js && vite build && node scripts/prerender-seo.js",
    "preview": "vite preview",
    "sitemap": "node scripts/generate-sitemap.js",
    "sync:medications": "node scripts/sync-medications-json.js",
    "sync:endpoints": "node sync_endpoints_to_neon.js",
    "generate-icons": "node scripts/generate-icons.js",
    "check:readability": "node scripts/check-readability.js",
    "snapshot:update": "node scripts/snapshot-pages.js --update",
    "snapshot:verify": "node scripts/snapshot-pages.js",
    "check:readability:strict": "node scripts/check-readability.js --strict",
    "check:links": "node scripts/check-links.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@neondatabase/serverless": "^0.10.4",
    "@supabase/supabase-js": "^2.89.0",
    "fuse.js": "^7.1.0",
    "i18next": "^26.3.4",
    "lucide-react": "^0.292.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^6.20.0",
    "resend": "^6.8.0",
    "stripe": "^20.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "dotenv": "^17.2.3",
    "playwright-core": "^1.61.1",
    "postcss": "^8.4.32",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.3.6",
    "terser": "^5.44.1",
    "vite": "^5.0.8",
    "vite-plugin-pwa": "^1.2.0",
    "workbox-window": "^7.4.0"
  }
}
